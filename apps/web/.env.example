# API URL (internal, server-side)
API_URL=http://localhost:3001

# API URL (public, client-side)
NEXT_PUBLIC_API_URL=http://localhost:3001

# Database (needed for Better Auth server-side session validation)
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# Auth (Better Auth)
BETTER_AUTH_SECRET=generate-a-32-char-secret-here-with-openssl-rand-base64-32
BETTER_AUTH_URL=http://localhost:3000
